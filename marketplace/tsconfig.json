{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@lib/*": ["./src/lib/*"],
      "@component/*": ["./src/components/*"],
      "@sections/*": ["./src/page-sections/*"],
      "@models/*": ["./src/models/*"],
      "@utils/*": ["./src/utils/*"],
      "@hook/*": ["./src/hooks/*"],
      "@contexts/*": ["./src/contexts/*"],
      "@context/*": ["./src/contexts/*"],
      "@data/*": ["./src/data/*"],
      "__server__": ["./src/__server__/index.ts"],
      "__server__/*": ["./src/__server__/*"],
      "components/*": ["./src/components/*"],
      "theme": ["./src/theme/index.ts"],
      "theme/*": ["./src/theme/*"],
      "utils/*": ["./src/utils/*"],
      "interfaces": ["./src/interfaces/index.ts"],
      "interfaces/*": ["./src/interfaces/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
