# =============================================================================
# USCG Backend - Configuration Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/uscg_db?schema=public"

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-here"
JWT_REFRESH_EXPIRES_IN="30d"

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# -----------------------------------------------------------------------------
# FILE UPLOAD
# -----------------------------------------------------------------------------
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880
# 5 MB = 5 * 1024 * 1024 = 5242880 bytes

# -----------------------------------------------------------------------------
# SUPER ADMIN (Seed)
# -----------------------------------------------------------------------------
SUPER_ADMIN_EMAIL="admin@uscg.com"
SUPER_ADMIN_PASSWORD="ChangeMe@123456"
SUPER_ADMIN_FIRSTNAME="Admin"
SUPER_ADMIN_LASTNAME="USCG"

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGIN="http://localhost:3000,http://localhost:3002"
# Comma-separated list of allowed origins (admin-panel, marketplace)

# -----------------------------------------------------------------------------
# EMAIL (Resend)
# -----------------------------------------------------------------------------
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY="re_ta_cle_api_ici"
# Email address to send from (must be verified in Resend dashboard)
RESEND_FROM_EMAIL="noreply@your-domain.com"
# Frontend URL for email verification links (Marketplace)
FRONTEND_URL="http://localhost:3003"
# Admin Panel URL for seller approval emails
ADMIN_PANEL_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# PHASE 2+ (Non utilisé en Phase 1)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM="noreply@uscg.com"