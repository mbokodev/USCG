// ============================================================================
// BANNER - Hero Carousel
// ============================================================================

model Banner {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  buttonText  String?
  buttonLink  String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
