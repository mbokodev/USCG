// FlashDeal Model - Ventes flash / Promotions

model FlashDeal {
  id String @id @default(cuid())

  // Lien vers l'annonce (qui doit avoir discountedPrice défini)
  adId String @unique
  ad   Ad     @relation(fields: [adId], references: [id], onDelete: Cascade)

  // Période de validité
  startDate DateTime  @default(now())
  endDate   DateTime?

  // Gestion
  isActive Boolean @default(true)
  order    Int     @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([startDate])
  @@index([endDate])
  @@index([order])
}
