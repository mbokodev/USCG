// LoginHistory Model - Historique des connexions

model LoginHistory {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ipAddress String
  userAgent String?

  // Timestamp de connexion
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}